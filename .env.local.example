# ⚠️ Projet Supabase "niche-signal" UNIQUEMENT — pas les clés Slidy !
# Project Settings → API (https://supabase.com/dashboard/project/niche-signal)
# URL = Project URL uniquement (PAS /rest/v1 ni /auth/v1)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Publishable key (ex-anon) depuis API Settings
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Secret — jamais exposé côté client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── IA pour l'analyse de marché (une seule clé suffit) ──────────────
# → https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxx
# Recommandé — gemini-2.5-flash (évite le score 78 par défaut du modèle lite)
GEMINI_MODEL=gemini-2.5-flash

# Alternative gratuite (Llama 3.3 70B, très rapide)
# → https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxxxxxxx

# Option payante (Claude Sonnet)
# → https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# GitHub Actions uniquement (pas dans .env.local)
# SUPABASE_PROJECT_REF=xxxxxxxx
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx

NEXT_PUBLIC_STRIPE_CHECKOUT_URL=https://buy.stripe.com/your-checkout-link

# Cron Vercel — génération mensuelle des opportunités (Authorization: Bearer <secret>)
# CRON_SECRET=your-random-secret
